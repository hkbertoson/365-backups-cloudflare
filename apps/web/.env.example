# better-auth server (used by src/lib/auth.ts via the Vite dev middleware)
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:5173
DATABASE_PATH=auth.db
# Comma-separated trusted origins. Defaults to BETTER_AUTH_URL when unset; set
# this when the SPA origin differs (127.0.0.1, an alternate Vite port, prod).
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# better-auth browser client (src/lib/auth-client.ts). Leave unset when the SPA
# and the auth API are served from the same origin (the default dev setup).
# VITE_AUTH_URL=http://localhost:5173
