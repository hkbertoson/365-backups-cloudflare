{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "365-backups-cloudflare",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-18",
	"observability": {
		"enabled": true,
	},
	"queues": {
		"consumers": [
			{
				"queue": "my-queue",
			},
		],
		"producers": [
			{
				"binding": "MY_QUEUE",
				"queue": "my-queue",
			},
		],
	},
	"upload_source_maps": true,
	"compatibility_flags": ["nodejs_compat"],
}
